# ── Database (free Postgres: Neon / Supabase / Railway) ──────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laundryos?schema=public"

# ── App ──────────────────────────────────────────────────────────────
PORT=8000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"

# ── Auth ─────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# ── Platform bootstrap (seed creates this super-admin) ───────────────
PLATFORM_ADMIN_EMAIL="admin@laundryos.dev"
PLATFORM_ADMIN_PASSWORD="Admin@123"
